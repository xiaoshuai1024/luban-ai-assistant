# luban-ai-assistant 环境变量样例
# 复制为 .env（本地）或经部署脚本注入，填入真实值。所有 key/secret 仅经环境变量，
# 禁入仓、禁入日志、禁入 Langfuse 明文。真实 .env / .env.dev 已 .gitignore，不入仓。

# ===== 应用 =====
ENVIRONMENT=dev
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]

# ===== FeatureGate =====
AI_GENERATE_ENABLED=true
AI_GUIDANCE_ENABLED=true

# ===== JWT（复用 luban AUTH_JWT_SECRET，务必与 engine/BFF 一致）=====
AUTH_JWT_SECRET=change-me-to-luban-secret
AUTH_JWT_ALGORITHM=HS256

# ===== 模型 provider：仅改这一行切换三家（运行期单一）=====
MODEL_PROVIDER=glm

# 智谱 GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通义千问（OpenAI 兼容模式）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 校验闸回环重试上限
VALIDATION_MAX_RETRIES=3

# ===== PostgreSQL =====
POSTGRES_DSN=postgresql://luban:luban@postgres:5432/luban_ai

# ===== Milvus =====
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=luban_materials

# ===== 云端 embedding =====
EMBEDDING_PROVIDER=glm
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_MODEL=embedding-3

# ===== MinIO =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-assets
MINIO_SECURE=false

# ===== Langfuse（自托管）=====
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
