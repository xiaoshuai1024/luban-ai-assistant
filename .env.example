# luban-ai-assistant 环境变量样例
# 复制为 .env（本地）或经部署脚本注入，填入真实值。所有 key/secret 仅经环境变量，
# 禁入仓、禁入日志。真实 .env / .env.dev 已 .gitignore，不入仓。

# ===== 应用 =====
ENVIRONMENT=dev
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]

# ===== FeatureGate =====
AI_GENERATE_ENABLED=true
AI_GUIDANCE_ENABLED=true

# ===== JWT（M3 后 BFF 服务间信任为主，JWT 自验降级可选）=====
AUTH_JWT_SECRET=change-me-to-luban-secret
AUTH_JWT_ALGORITHM=HS256

# ===== 模型 provider：仅改这一行切换三家（运行期单一）=====
# 迁移说明（M0）：默认 provider 从 glm 改为 deepseek（M1 后由 LiteLLM 路由）
MODEL_PROVIDER=deepseek

# 智谱 GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4

# DeepSeek（首选）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通义千问（OpenAI 兼容模式）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 校验闸回环重试上限
VALIDATION_MAX_RETRIES=3

# ===== PostgreSQL =====
POSTGRES_DSN=postgresql://luban:luban@postgres:5432/luban_ai

# ===== Qdrant（迁移后向量库）=====
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ===== 云端 embedding =====
EMBEDDING_PROVIDER=glm
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_MODEL=embedding-3

# ===== Langfuse（已移除，M0 迁移）=====
# 迁移说明：自托管 Langfuse 可观测已移除，tracer 默认 NoopTracer。
# 后续接入 OTel 等可观测再启用。以下字段保留供 config.py 加载（M1/M2 清理）。
# LANGFUSE_HOST=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
