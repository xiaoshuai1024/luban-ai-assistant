# docker-compose.override.yml 样例
# 复制为 docker-compose.override.yml（已 .gitignore），用于本地覆盖（如挂源码热重载、改端口）。
# 真实覆盖文件不入仓。

services:
  fastapi:
    build:
      context: .
      target: builder
    # 挂源码 + 热重载（仅本地）
    volumes:
      - ./app:/app/app
    command: ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
